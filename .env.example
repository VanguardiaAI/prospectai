# ProspectAI — Variables de entorno
# Copia este archivo como .env.local y rellena los valores

# ── IA ────────────────────────────────────────────────────────────────────────
# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Resend webhook signing secret (Resend → Webhooks → tu endpoint → Signing Secret)
# Formato: whsec_xxxxxxxxxxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=

# ── Autenticación ─────────────────────────────────────────────────────────────
# Usuario de login
AUTH_USERNAME=admin

# Hash bcrypt de la contraseña. Genera uno con:
#   node -e "require('bcryptjs').hash('TU_PASSWORD', 12).then(console.log)"
AUTH_PASSWORD_HASH=

# Secreto para firmar JWT (minimo 32 caracteres). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# ── Cron ──────────────────────────────────────────────────────────────────────
# Secreto para proteger el endpoint /api/cron desde cron jobs externos
# Se envía como: Authorization: Bearer <CRON_SECRET>
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Opcional ──────────────────────────────────────────────────────────────────
# Python path si no está en el PATH del sistema (default: python3)
# PYTHON_PATH=/usr/local/bin/python3
