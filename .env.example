# ProspectAI — Environment Variables
# Copy this file as .env.local and fill in the values

# ── Site URL ─────────────────────────────────────────────────────────────────
# Public URL where the app is hosted (used for metadata, tracking links, etc.)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── AI ───────────────────────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Resend webhook signing secret (Resend > Webhooks > your endpoint > Signing Secret)
# Format: whsec_xxxxxxxxxxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=

# ── Authentication ───────────────────────────────────────────────────────────
# Login username
AUTH_USERNAME=admin

# bcrypt password hash. Generate one with:
#   node -e "require('bcryptjs').hash('YOUR_PASSWORD', 12).then(console.log)"
AUTH_PASSWORD_HASH=

# JWT signing secret (minimum 32 characters). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# ── Cron ─────────────────────────────────────────────────────────────────────
# Secret to protect the /api/cron endpoint from external cron jobs
# Sent as: Authorization: Bearer <CRON_SECRET>
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────
# Python path if not in system PATH (default: python3)
# PYTHON_PATH=/usr/local/bin/python3
